<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error | AWS Cognito Demo</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background: #f4f6f9;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .card {
            width: 650px;
            background: white;
            border-radius: 10px;
            padding: 40px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,.15);
        }

        h1 {
            color: #d9534f;
            margin-bottom: 20px;
        }

        h3 {
            color: #232F3E;
            margin-bottom: 20px;
        }

        p {
            margin-bottom: 30px;
            color: #555;
            word-wrap: break-word;
        }

        .btn {
            display: inline-block;
            padding: 12px 28px;
            background: #FF9900;
            color: white;
            text-decoration: none;
            border-radius: 6px;
            font-weight: bold;
        }

        .btn:hover {
            background: #e68a00;
        }

        .box {
            background: #f8f8f8;
            border: 1px solid #ddd;
            padding: 15px;
            text-align: left;
            border-radius: 5px;
            overflow-x: auto;
            font-family: monospace;
            margin-bottom: 30px;
            white-space: pre-wrap;
        }
    </style>
</head>

<body>

    <div class="card">

        <h1>⚠️ Something Went Wrong</h1>

        <h3>Authentication Error</h3>

        <div class="box">
<%= message %>
        </div>

        <a href="/" class="btn">
            Return Home
        </a>

    </div>

</body>

</html>
