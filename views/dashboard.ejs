<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | AWS Cognito Demo</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background: #f4f6f9;
        }

        .navbar {
            background: #232F3E;
            color: white;
            padding: 18px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar h2 {
            font-size: 22px;
        }

        .logout {
            text-decoration: none;
            color: white;
            background: #FF9900;
            padding: 10px 18px;
            border-radius: 5px;
            font-weight: bold;
        }

        .logout:hover {
            background: #e58b00;
        }

        .container {
            width: 90%;
            max-width: 1100px;
            margin: 40px auto;
        }

        .card {
            background: white;
            padding: 25px;
            border-radius: 8px;
            margin-bottom: 25px;
            box-shadow: 0 5px 12px rgba(0,0,0,.1);
        }

        h3 {
            margin-bottom: 20px;
            color: #232F3E;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
            vertical-align: top;
        }

        td:first-child {
            width: 220px;
            font-weight: bold;
            background: #fafafa;
        }

        textarea {
            width: 100%;
            min-height: 170px;
            resize: vertical;
            padding: 12px;
            border-radius: 5px;
            border: 1px solid #ccc;
            font-family: monospace;
        }

        .footer {
            text-align: center;
            color: gray;
            margin: 40px;
        }
    </style>

</head>

<body>

    <div class="navbar">
        <h2>AWS Cognito Dashboard</h2>

        <a href="/logout" class="logout">
            Logout
        </a>
    </div>

    <div class="container">

        <div class="card">

            <h3>User Information</h3>

            <table>

                <% Object.keys(user).forEach(function(key){ %>

                <tr>
                    <td><%= key %></td>
                    <td><%= user[key] %></td>
                </tr>

                <% }) %>

            </table>

        </div>

        <div class="card">

            <h3>ID Token</h3>

            <textarea readonly><%= tokens.id_token %></textarea>

        </div>

        <div class="card">

            <h3>Access Token</h3>

            <textarea readonly><%= tokens.access_token %></textarea>

        </div>

        <% if(tokens.refresh_token){ %>

        <div class="card">

            <h3>Refresh Token</h3>

            <textarea readonly><%= tokens.refresh_token %></textarea>

        </div>

        <% } %>

    </div>

    <div class="footer">
        Amazon Cognito Hosted UI Authentication Demo
    </div>

</body>

</html>
